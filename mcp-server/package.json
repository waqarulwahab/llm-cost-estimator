{
  "name": "llm-cost-estimator-mcp",
  "version": "0.3.1",
  "mcpName": "io.github.waqarulwahab/llm-cost-estimator",
  "description": "MCP server for LLM token counting and multi-model cost estimation (GPT-4o, Claude, Gemini, and 25+ models). Local-first, no API key.",
  "license": "MIT",
  "author": "waqarulwahab",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/waqarulwahab/llm-cost-estimator.git",
    "directory": "mcp-server"
  },
  "keywords": ["mcp", "model-context-protocol", "llm", "tokens", "tiktoken", "cost", "openai", "anthropic", "gemini"],
  "homepage": "https://github.com/waqarulwahab/llm-cost-estimator/tree/main/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/waqarulwahab/llm-cost-estimator/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "llm-cost-estimator-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:prod": "node build.mjs --production",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "node build.mjs && node scripts/mcp-test.mjs",
    "prepublishOnly": "node build.mjs --production"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "js-tiktoken": "^1.0.21",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "esbuild": "^0.23.1",
    "typescript": "^5.9.3"
  }
}
